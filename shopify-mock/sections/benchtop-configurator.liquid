{%- comment -%}
  Illustrative only — not wired. See shopify-mock/README.md.
  Mount the React prototype on any page using this section.
{%- endcomment -%}

<div class="bt-section">
  {% if section.settings.heading != blank %}
    <h1 class="bt-section__h">{{ section.settings.heading }}</h1>
  {% endif %}
  {% if section.settings.intro != blank %}
    <p class="bt-section__intro">{{ section.settings.intro }}</p>
  {% endif %}

  {%- render 'benchtop-config-data' -%}

  <div id="innate-benchtop-root" class="bt-root"></div>

  {{ 'benchtop-configurator.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'benchtop-configurator.js' | asset_url }}" defer></script>
</div>

<style>
  .bt-section { max-width: 1280px; margin: 0 auto; padding: 32px 20px; }
  .bt-section__h { font-family: "Maven Pro", system-ui, sans-serif; font-size: 2rem; margin: 0 0 .25rem; color: #163832; }
  .bt-section__intro { color: #14141399; font-size: 1.02rem; margin: 0 0 2rem; max-width: 56ch; }
  .bt-root { min-height: 640px; }
</style>

{% schema %}
{
  "name": "Benchtop configurator",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Benchtops" },
    { "type": "textarea", "id": "intro", "label": "Intro copy", "default": "Solid timber benchtops, cut to your size. Three NZ species. Six week lead time." }
  ],
  "presets": [
    { "name": "Benchtop configurator" }
  ]
}
{% endschema %}
