{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/send-quote.ts": {
      "includeFiles": "node_modules/**/@resvg/resvg-js-linux-x64-gnu/**"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
